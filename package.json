{
  "name": "ahp-portfolio",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "cd apps/api && py -m uvicorn main:app --reload --port 8000",
    "dev:web": "cd apps/web && npm run dev",
    "build": "cd apps/web && npm run build",
    "install:all": "cd apps/web && npm install"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
